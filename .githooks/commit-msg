#!/usr/bin/env bash
# NightForge commit-msg hook.
# Enforces docs/COMMIT_AND_PR_STYLE.md.
# Install: git config core.hooksPath .githooks
set -e

MSG_FILE="$1"
TITLE=$(grep -v '^#' "$MSG_FILE" | sed '/./,$!d' | head -n 1)

# Allow git's own merge / revert headers.
case "$TITLE" in Merge*|Revert*|"fixup!"*|"squash!"*) exit 0 ;; esac

ALLOWED='^(api|web|tools|explorer|data|nginx|docs|build|perf|ui|truth):'
MAX=72
BANNED='update|updates|stuff|misc|changes|various|wow|tweak|tweaks'

fail() {
  echo ""
  echo "  commit message rejected: $1" >&2
  echo "  title:    \"$TITLE\"" >&2
  echo "  format:   <scope>: <lowercase imperative action>" >&2
  echo "  scopes:   api | web | tools | explorer | data | nginx | docs | build | perf | ui | truth" >&2
  echo "  rules:    max ${MAX} chars; no banned words ($BANNED); no AI attribution" >&2
  echo "  see:      docs/COMMIT_AND_PR_STYLE.md" >&2
  echo ""
  exit 1
}

[ -z "$TITLE" ] && fail "title is empty"
[ ${#TITLE} -gt $MAX ] && fail "title is ${#TITLE} chars (max ${MAX})"

echo "$TITLE" | grep -qE "$ALLOWED " || fail "missing or unknown scope"
echo "$TITLE" | grep -qE "^[a-z]+: [a-z]" || fail "action must start lowercase (imperative)"

# Soft tense check: catch obvious -ing / -ed / 3p-singular verb endings.
VERB=$(echo "$TITLE" | sed -E 's/^[a-z]+: ([a-z]+).*/\1/')
case "$VERB" in
  *ing|*ed) fail "verb '$VERB' is not imperative (no -ing or -ed)" ;;
  updates|fixes|adds|removes|bumps|cleans|breaks|wraps|merges)
    fail "verb '$VERB' is not imperative (drop the trailing 's')" ;;
esac

LOWER=$(echo " $TITLE " | tr '[:upper:]' '[:lower:]')
for w in $(echo "$BANNED" | tr '|' ' '); do
  echo "$LOWER" | grep -qE "[^a-z]${w}[^a-z]" && fail "banned vague word '$w'"
done

# No AI / Claude / Copilot attribution anywhere in the message.
grep -qiE 'claude|copilot|chatgpt|generated by ai|co-authored-by:.*(claude|ai|copilot)' "$MSG_FILE" \
  && fail "AI attribution is not allowed"

exit 0
